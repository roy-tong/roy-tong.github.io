---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}{{ '/' | relative_url }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
  {% assign public_pages = site.pages | where_exp: "item", "item.url != '/support/' and item.url != '/404.html' and item.url != '/sitemap.xml'" %}
  {% for item in public_pages %}
    {% unless item.url == '/' %}
  <url>
    <loc>{{ site.url }}{{ item.url | relative_url }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
    {% endunless %}
  {% endfor %}
  {% for post in site.posts %}
  <url>
    <loc>{{ site.url }}{{ post.url | relative_url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
  {% endfor %}
</urlset>
